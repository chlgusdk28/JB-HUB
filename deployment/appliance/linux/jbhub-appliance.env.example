NODE_ENV=production
API_PORT=8787
SERVE_STATIC_DIST=1

# SQLite 단일 노드 기본값
API_JWT_HS256_SECRET=change-this-secret-min-32-chars-long
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me

# 정적 사이트를 같은 프로세스에서 제공하므로 보통 같은 오리진이면 충분합니다.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787

# 컨테이너 런타임 어댑터 기본값
CONTAINER_RUNTIME_KIND=docker
CONTAINER_RUNTIME_BIN=docker
CONTAINER_RUNTIME_COMPOSE_COMMAND=compose

# 미리보기 호스트
DOCKER_PREVIEW_HOST=127.0.0.1
