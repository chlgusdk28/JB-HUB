# ========================================
# JB-Hub Production Environment Template
# ========================================
# ⚠️  보안 경고: .env 파일을 절대 커밋하지 마세요!
# 복사하여 .env.production을 만들고 모든 값을 설정하세요

# ========================================
# Server Configuration
# ========================================
API_PORT=8787
NODE_ENV=production

# ========================================
# Database Configuration
# ========================================
# 강력한 비밀번호 생성: openssl rand -base64 32
DB_HOST=your-db-host
DB_PORT=3310
DB_USER=jbhub_user
DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
DB_NAME=jbhub
DB_CONN_LIMIT=20

# ⚠️  프로덕션에서는 반드시 false로 설정!
DB_SEED=false
DB_CONNECT_RETRY_ATTEMPTS=40
DB_CONNECT_RETRY_DELAY_MS=2000

# ========================================
# Security - CORS Configuration (CRITICAL)
# ========================================
# ⚠️  콤마로 구분된 특정 도메인만 허용!
# 프로덕션에서는 반드시 HTTPS 도메인만 사용하세요
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ========================================
# Security - Authentication / JWT
# ========================================
# 강력한 JWT 시크릿 생성: openssl rand -base64 48
API_JWT_HS256_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_MIN_48_CHARS
API_JWT_ISSUER=jbhub-api
API_JWT_AUDIENCE=jbhub-client

# 인증 모드: 프로덕션에서는 반드시 'jwt'
API_AUTH_MODE=jwt
API_ALLOW_DEV_HEADER_AUTH=false  # MUST be false in production!

# 토큰 만료 시간 (초)
JWT_ACCESS_TOKEN_EXPIRATION=3600        # 1시간
JWT_REFRESH_TOKEN_EXPIRATION=86400      # 24시간

# ========================================
# Rate Limiting (DDoS Protection)
# ========================================
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120

# ========================================
# Admin Configuration
# ========================================
# 기본 관리자 비밀번호 변경 필수!
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
ADMIN_DEFAULT_EMAIL=admin@your-domain.com

ADMIN_SESSION_TIMEOUT_MS=3600000      # 1시간
ADMIN_MAX_LOGIN_ATTEMPTS=5
ADMIN_LOCKOUT_DURATION_MS=900000      # 15분

# ========================================
# Audit Log Configuration
# ========================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ========================================
# Frontend Configuration (Production)
# ========================================
VITE_API_BASE_URL=https://api.your-domain.com

# ========================================
# SSL/TLS Configuration
# ========================================
# SSL_CERT_PATH=/path/to/ssl/cert.pem
# SSL_KEY_PATH=/path/to/ssl/key.pem
# TRUST_PROXY=true

# ========================================
# Monitoring & Logging (Optional)
# ========================================
# SENTRY_DSN=
# LOG_LEVEL=info